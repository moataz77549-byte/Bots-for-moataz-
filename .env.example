# ══════════════════════════════════════
# Telegram
# ══════════════════════════════════════
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated user IDs allowed to use the bot (leave empty for public)
ALLOWED_USER_IDS=123456789,987654321

# Whether to allow all users when ALLOWED_USER_IDS is empty.
# Set to false to require explicit whitelisting.
ALLOW_ALL=true

# Comma-separated admin IDs with elevated privileges (optional).
ADMIN_IDS=123456789

# ══════════════════════════════════════
# Admin Dashboard
# ══════════════════════════════════════
ADMIN_PASSWORD=your_secure_admin_password
SESSION_SECRET=your_random_session_secret
PORT=5000

# Enable webhook mode and specify the full public HTTPS URL for Telegram to call.
# If USE_WEBHOOK=true and WEBHOOK_URL is set, the bot will run without polling.
USE_WEBHOOK=false
WEBHOOK_URL=

# Optional: If your hosting platform idles after inactivity you can set
# KEEPALIVE_URL to the root of your deployed app (e.g. https://your.app). The
# bot will periodically ping this URL to keep it alive. Leave empty to disable.
KEEPALIVE_URL=

# ══════════════════════════════════════
# Proxy (optional)
# Supported formats: http://host:port  |  socks5://host:port  |  http://user:pass@host:port
# ══════════════════════════════════════
PROXY_URL=

# ══════════════════════════════════════
# Cookies — paste full Netscape cookies.txt content as ENV value
# How to export: use browser extension "Get cookies.txt LOCALLY"
# Then paste the entire file content as the value below (multi-line supported)
# ══════════════════════════════════════
COOKIES_YOUTUBE=
COOKIES_INSTAGRAM=
COOKIES_TIKTOK=
COOKIES_FACEBOOK=
COOKIES_TWITTER=

# ══════════════════════════════════════
# Cookies directory (auto-created, no need to change)
# ══════════════════════════════════════
COOKIES_DIR=cookies/

# Storage channel ID used to store files on Telegram for caching.
# You can create a private channel and add the bot as an admin.
STORAGE_CHANNEL_ID=
